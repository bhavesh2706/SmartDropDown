{
  "name": "react-native-smart-dropdown",
  "version": "0.1.2",
  "description": "Production-ready, reusable React Native dropdown/select with smart positioning, search, and multi-select. Zero runtime dependencies.",
  "keywords": [
    "react-native",
    "react-native-dropdown",
    "dropdown",
    "select",
    "picker",
    "multi-select",
    "single-select",
    "autocomplete",
    "combobox",
    "searchable-dropdown",
    "react-native-picker",
    "react-native-select",
    "react-native-component",
    "typescript",
    "mobile-ui",
    "form-component",
    "ios",
    "android",
    "cross-platform",
    "smart-dropdown"
  ],
  "license": "MIT",
  "author": "Bhavesh Barot <bhaveshbarot2706@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bhavesh2706/SmartDropDown.git"
  },
  "bugs": {
    "url": "https://github.com/bhavesh2706/SmartDropDown/issues"
  },
  "homepage": "https://github.com/bhavesh2706/SmartDropDown#readme",
  "source": "./src/index.ts",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "react-native": "./src/index.ts",
  "types": "./lib/typescript/commonjs/src/index.d.ts",
  "sideEffects": false,
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/*.test.ts",
    "!**/*.test.tsx",
    "!**/*.map",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "build": "bob build",
    "prepare": "bob build",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0"
  },
  "devDependencies": {
    "@react-native/babel-preset": "0.86.0",
    "@react-native/jest-preset": "0.86.0",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "jest": "^29.7.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-builder-bob": "^0.43.0",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "jest": {
    "preset": "@react-native/jest-preset",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|@testing-library)/)"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/example/",
      "/lib/"
    ],
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ]
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
